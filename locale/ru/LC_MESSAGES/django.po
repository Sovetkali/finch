msgid "Welcome back"
msgstr "С возвращением"

msgid "Close"
msgstr "Закрыть"

msgid "Invalid username or password."
msgstr "Неверное имя пользователя или пароль."

msgid "Forgot password?"
msgstr "Забыли пароль?"

msgid "No account?"
msgstr "Нет аккаунта?"

msgid "Create your unique account"
msgstr "Создайте свой уникальный аккаунт"

msgid "Create account"
msgstr "Создать аккаунт"

msgid "Already have an account?"
msgstr "Уже есть аккаунт?"

msgid "Menu"
msgstr "Меню"

msgid "Toggle theme"
msgstr "Переключить тему"

msgid "Light theme"
msgstr "Светлая тема"

msgid "Dark theme"
msgstr "Темная тема"
