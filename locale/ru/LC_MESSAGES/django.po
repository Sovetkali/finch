msgstr "Подписан"

msgid "Following you since"
msgstr "Читает вас с"

msgid "Mutual"
msgstr "Взаимно"

msgid "Nobody follows you yet."
msgstr "Вас пока никто не читает."

msgid "You are not subscribed to anyone yet."
msgstr "Вы пока ни на кого не подписаны."

msgid "Friend search is not available yet. We are working on it."
msgstr "Поиск друзей пока недоступен. Мы работаем над ним."

msgid "Mark all as read"
msgstr "Отметить всё как прочитанное"

msgid "@%(username)s mentioned you"
msgstr "@%(username)s упомянул(а) вас"

msgid "@%(username)s commented on your post"
msgstr "@%(username)s оставил(а) комментарий к вашей записи"

msgid "@%(username)s followed you"
msgstr "@%(username)s подписался(-ась) на вас"

msgid "New"
msgstr "Новое"

msgid "No notifications yet."
msgstr "Уведомлений пока нет."

msgid "Welcome"
msgstr "Добро пожаловать"

msgid "Share your link with friends so they can subscribe to your content."
msgstr "Поделитесь своей ссылкой с друзьями, чтобы они могли подписаться на ваш контент."

msgid "Copy link"
msgstr "Скопировать ссылку"

msgid "Go to feed"
msgstr "Перейти к ленте"

msgid "Link copied to clipboard"
msgstr "Ссылка скопирована в буфер обмена"

msgid "Email"
msgstr "Почта"

