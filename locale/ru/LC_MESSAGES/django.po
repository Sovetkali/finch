msgstr "Лента финчей доступна только участникам сети."

msgid "Link copied!"
msgstr "Ссылка скопирована!"

msgid "Text cannot exceed 140 characters."
msgstr "Текст не может превышать 140 символов."

msgid "Share"
msgstr "Поделиться"

msgid "Follow"
msgstr "Подписаться"

msgid "Unfollow"
msgstr "Отписаться"

msgid "No posts yet. Be first!"
msgstr "Записей пока нет. Будьте первым!"

msgid "%(username)s's profile"
msgstr "Профиль %(username)s"

msgid "Share profile"
msgstr "Поделиться профилем"

msgid "Delete account"
msgstr "Удалить аккаунт"

msgid "Are you sure you want to delete this post?"
msgstr "Вы уверены, что хотите удалить этот пост?"

msgid "Delete"
msgstr "Удалить"

