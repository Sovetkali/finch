msgstr "Это действие необратимо. Будут безвозвратно удалены:"

msgid "Your profile and login data"
msgstr "Ваш профиль и данные для входа"

msgid "All your posts"
msgstr "Все ваши записи"

msgid "All your subscriptions"
msgstr "Все ваши подписки"

